{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "mock": "vite --config vite.mock.config.ts",
    "mock-animate": "MOCK_ANIMATE=1 vite --config vite.mock.config.ts",
    "mock-annotate": "MOCK_ANIMATE=1 MOCK_ANNOTATE=1 vite --config vite.mock.config.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "tauri": "tauri",
    "build:sidecar": "node scripts/sidecar-build.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "dompurify": "^3.4.5",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.168",
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
